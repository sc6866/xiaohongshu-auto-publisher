# =========================
# 镜像与基础服务
# =========================
# 一般不用改，保持默认即可
XHS_APP_IMAGE=ghcr.io/sc6866/xiaohongshu-auto-publisher:latest
XHS_WEB_HOST=0.0.0.0
XHS_WEB_PORT=8787

# =========================
# 外网访问地址
# =========================
# 如果你已经配置了 Cloudflare Tunnel 或反代域名，就填完整 URL
# 例子：https://xhs.example.com
# 如果暂时只在本机/局域网使用，可以先留空
XHS_WEB_PUBLIC_BASE_URL=

# =========================
# 宿主机小红书 MCP 地址
# =========================
# 默认适合 Docker 容器访问宿主机上的已登录 MCP
XHS_MCP_BASE_URL=http://host.docker.internal:18090
XHS_MCP_AUTO_START=false

# =========================
# 可选：账号绑定信息
# =========================
# 如果你希望远程部署时也直接带上当前账号资料，可以填
# 不填也可以，项目仍然能运行，只是部分“回流/作品同步”能力可能受影响
XHS_PUBLISHER_USER_ID=
XHS_PUBLISHER_XSEC_TOKEN=

# =========================
# 必填：模型与 OCR
# =========================
# 阿里百炼 / 通义千问 API Key
DASHSCOPE_API_KEY=请替换成你的通义千问API_KEY

# 百度 OCR API Key
BAIDU_OCR_API_KEY=请替换成你的百度OCR_API_KEY

# 百度 OCR Secret Key
BAIDU_OCR_SECRET_KEY=请替换成你的百度OCR_SECRET_KEY

# =========================
# 可选：Cloudflare Tunnel
# =========================
# 如果要外网访问，就填写 Cloudflare Zero Trust 生成的 Tunnel Token
# 不需要外网访问时可以留空
CF_TUNNEL_TOKEN=

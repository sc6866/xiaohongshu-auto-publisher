# =========================
# Image and app basics
# =========================
XHS_APP_IMAGE=ghcr.io/sc6866/xiaohongshu-auto-publisher:latest
XHS_WEB_HOST=0.0.0.0
XHS_WEB_PORT=8787

# =========================
# VPS domain and HTTPS
# =========================
APP_DOMAIN=your-domain.example.com
ENABLE_HTTPS=true
SSL_EMAIL=admin@your-domain.example.com

# =========================
# Public URL
# =========================
XHS_WEB_PUBLIC_BASE_URL=https://your-domain.example.com

# =========================
# Reachable MCP endpoint
# =========================
# If you deploy on Linux VPS, this must be a real MCP endpoint that the VPS can reach.
XHS_MCP_BASE_URL=http://host.docker.internal:18090
XHS_MCP_AUTO_START=false

# =========================
# Optional publisher binding
# =========================
XHS_PUBLISHER_USER_ID=
XHS_PUBLISHER_XSEC_TOKEN=

# =========================
# Required model and OCR keys
# =========================
DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
BAIDU_OCR_API_KEY=replace_with_your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=replace_with_your_baidu_ocr_secret_key

# =========================
# Optional Cloudflare Tunnel
# =========================
CF_TUNNEL_TOKEN=
